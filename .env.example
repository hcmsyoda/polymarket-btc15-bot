# PolyBot Configuration — copy to .env and fill in your values
# NEVER commit .env to git

# Wallet
PRIVATE_KEY=your_private_key_here_without_0x
WALLET_ADDRESS=your_eoa_wallet_address

# Safe wallet (optional — leave empty for EOA-only)
SAFE_ADDRESS=

# Builder config (optional — leave empty if not using a builder)
BUILDER_ADDRESS=
BUILDER_FEE=

# Trading mode
DRY_RUN=true

# Strategy parameters
MIN_EDGE=0.05
MIN_PROB=0.80
MIN_BTC_DELTA=0.06
ENTRY_WINDOW_START=240
ENTRY_WINDOW_END=10
KELLY_FRACTION=0.25
MIN_BET=5.0
MAX_BET=25.0
BANKROLL=100.0
DAILY_LOSS_LIMIT=30.0

# Risk parameters
ROLLING_VOL_WINDOWS=12
VOL_FLOOR=0.06
VOL_CAP=0.30

# Logging
LOG_DIR=logs
LOG_EXECUTIONS=false

# Market period (minutes)
MARKET_PERIOD=5
